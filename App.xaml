<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:HomeAppLBO.Converters"
             xmlns:effects="clr-namespace:HomeAppLBO.Effects"
             x:Class="HomeAppLBO.App">

    <Application.Resources>
        <ResourceDictionary>

            <!-- =============================== -->
            <!--     🎨 COULEURS PRINCIPALES     -->
            <!-- =============================== -->

            <Color x:Key="DashboardBackground">#1A1A1A</Color>
            <Color x:Key="CardBackground">#242424</Color>
            <Color x:Key="CardShadowColor">#000000</Color>

            <Color x:Key="PrimaryTextColor">#FFFFFF</Color>
            <Color x:Key="SecondaryTextColor">#BBBBBB</Color>

            <!-- Jaune premium (lumière ON, météo) -->
            <Color x:Key="AccentYellow">#FFD27F</Color>

            <!-- Dégradé météo (valeurs par défaut pour éviter les ressources nulles au rendu initial) -->
            <Color x:Key="GradientTop">#4A90E2</Color>
            <Color x:Key="GradientBottom">#00337F</Color>

            <!--<Color x:Key="SurfacePage">#111827</Color>
            <Color x:Key="SurfaceCard">#1F2937</Color>
            <Color x:Key="SurfaceCardAlt">#374151</Color>-->

            <!--<Color x:Key="TextPrimary">#F9FAFB</Color>
            <Color x:Key="TextSecondary">#D1D5DB</Color>-->
            <Color x:Key="TextDark">#111827</Color>

            <!--<Color x:Key="AccentPrimary">#FBBF24</Color>-->
            <Color x:Key="AccentPrimaryPressed">#F59E0B</Color>
            <Color x:Key="ActionNeutral">#374151</Color>
            <Color x:Key="ActionDanger">#EF4444</Color>
            <Color x:Key="OutlineSoft">#4B5563</Color>

            <Color x:Key="SurfacePage">#0F172A</Color>
            <Color x:Key="SurfaceCard">#1E293B</Color>
            <Color x:Key="SurfaceCardAlt">#334155</Color>

            <Color x:Key="TextPrimary">White</Color>
            <Color x:Key="TextSecondary">#94A3B8</Color>

            <Color x:Key="AccentPrimary">#38BDF8</Color>

            <Color x:Key="WeatherTint">#0EA5E9</Color>
            <Color x:Key="WeatherTintSoft">#082F49</Color>

            <Color x:Key="ShuttersTint">#F59E0B</Color>
            <Color x:Key="ShuttersTintSoft">#451A03</Color>

            <Color x:Key="LightsTint">#FACC15</Color>
            <Color x:Key="LightsTintSoft">#422006</Color>

            <Color x:Key="SecurityTint">#A855F7</Color>
            <Color x:Key="SecurityTintSoft">#3B0764</Color>

            <Color x:Key="EnergyTint">#22C55E</Color>
            <Color x:Key="EnergyTintSoft">#052E16</Color>


            <!-- ================================= -->
            <!--     🎨 STYLE DES CARTES PREMIUM    -->
            <!-- ================================= -->

            <Style x:Key="DashboardCardStyle" TargetType="Frame">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBackground}" />
                <Setter Property="CornerRadius" Value="22" />
                <Setter Property="Padding" Value="15" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Shadow">
                    <Shadow Brush="{StaticResource CardShadowColor}"
                            Offset="0,6"
                            Radius="18"
                            Opacity="0.25" />
                </Setter>
            </Style>


            <!-- ================================= -->
            <!--     🎨 STYLE TITRE / SOUS TITRE    -->
            <!-- ================================= -->

            <Style x:Key="DashboardTitle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource PrimaryTextColor}" />
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="DashboardSubtitle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
                <Setter Property="FontSize" Value="16" />
            </Style>


            <!-- ================================= -->
            <!--      🔌 CONVERTISSEURS LUMIÈRES     -->
            <!-- ================================= -->

            <converters:BoolToSwitchColorConverter x:Key="BoolToSwitchColor" />
            <converters:BoolToThumbPositionConverter x:Key="BoolToThumbPosition" />


            <!-- ================================= -->
            <!--         Convertisseurs            -->
            <!-- ================================= -->

            <converters:PercentToProgressConverter x:Key="PercentToProgressConverter"/>

        </ResourceDictionary>
    </Application.Resources>

</Application>