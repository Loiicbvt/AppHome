<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="HomeAppLBO.Home.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Maison"
    BackgroundColor="{StaticResource SurfacePage}">

    <ScrollView>
        <VerticalStackLayout
            Padding="20,18,20,30"
            Spacing="16">

            <!-- HERO -->
            <Border
                x:Name="HeroCard"
                Padding="22"
                BackgroundColor="{StaticResource SurfaceCard}"
                Stroke="{StaticResource OutlineSoft}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 30"
                Opacity="0"
                TranslationY="20">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="{Binding Greeting}"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="{StaticResource AccentPrimary}" />

                    <Label
                        Text="{Binding WelcomeTitle}"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        Text="{Binding WelcomeSubtitle}"
                        FontSize="15"
                        TextColor="{StaticResource TextSecondary}" />

                    <BoxView
                        HeightRequest="1"
                        Color="{StaticResource OutlineSoft}" />

                    <Label
                        Text="{Binding QuoteText}"
                        FontSize="15"
                        FontAttributes="Italic"
                        LineBreakMode="WordWrap"
                        TextColor="{StaticResource TextPrimary}" />

                    <Label
                        Text="{Binding QuoteAuthor, StringFormat='— {0}'}"
                        FontSize="13"
                        HorizontalTextAlignment="End"
                        TextColor="{StaticResource TextSecondary}" />

                </VerticalStackLayout>
            </Border>
            <!-- ACTIONS RAPIDES -->
            <VerticalStackLayout Spacing="10">

                <Label
        Text="Actions rapides"
        FontSize="20"
        FontAttributes="Bold"
        TextColor="{StaticResource TextPrimary}" />

                <CollectionView
        ItemsSource="{Binding QuickActions}"
        HeightRequest="120"
        SelectionMode="None">

                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                    Padding="16"
                    WidthRequest="160"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource OutlineSoft}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 22">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnQuickActionTapped" />
                                </Border.GestureRecognizers>

                                <VerticalStackLayout Spacing="8">
                                    <Label
                            Text="{Binding Icon}"
                            FontSize="28" />

                                    <Label
                            Text="{Binding Title}"
                            FontSize="16"
                            FontAttributes="Bold"
                            TextColor="{StaticResource TextPrimary}" />

                                    <Label
                            Text="{Binding Subtitle}"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                </CollectionView>

            </VerticalStackLayout>

            <!-- MAIN GRID -->
            <Grid
                x:Name="MainCardsGrid"
                ColumnDefinitions="*,*"
                RowDefinitions="Auto,Auto,Auto,Auto"
                ColumnSpacing="14"
                RowSpacing="14">

                <!-- WEATHER -->
                <Border
                    x:Name="WeatherCard"
                    Grid.Row="0"
                    Grid.Column="0"
                    Padding="18"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource WeatherTint}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    Opacity="0"
                    TranslationY="20">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnWeatherTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Météo"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="{Binding HomeWeatherSubtitle}"
                                    FontSize="13"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10"
                                BackgroundColor="{StaticResource WeatherTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                                <Label
                                    Text="{Binding HomeWeatherIcon}"
                                    FontSize="26"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="2">
                            <Label
                                Text="{Binding HomeWeatherTemperature}"
                                FontSize="32"
                                FontAttributes="Bold"
                                TextColor="{StaticResource WeatherTint}" />

                            <Label
                                Text="{Binding HomeWeatherCondition}"
                                FontSize="14"
                                TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>

                        <CollectionView
                            ItemsSource="{Binding WeatherPreviewItems}"
                            HeightRequest="90"
                            SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,8,0"
                                        Padding="10"
                                        BackgroundColor="{StaticResource WeatherTintSoft}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 16">
                                        <VerticalStackLayout Spacing="4">
                                            <Label
                                                Text="{Binding TimeLabel}"
                                                FontSize="12"
                                                HorizontalTextAlignment="Center"
                                                TextColor="{StaticResource TextSecondary}" />

                                            <Label
                                                Text="{Binding Icon}"
                                                FontSize="18"
                                                HorizontalTextAlignment="Center" />

                                            <Label
                                                Text="{Binding Temperature}"
                                                FontSize="14"
                                                FontAttributes="Bold"
                                                HorizontalTextAlignment="Center"
                                                TextColor="{StaticResource TextPrimary}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

                <!-- SHUTTERS -->
                <Border
                    x:Name="ShuttersCard"
                    Grid.Row="0"
                    Grid.Column="1"
                    Padding="18"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource ShuttersTint}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    Opacity="0"
                    TranslationY="20">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnShuttersTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Volets"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="{Binding ShutterSummary}"
                                    FontSize="13"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10"
                                BackgroundColor="{StaticResource ShuttersTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                                <Label
                                    Text="🪟"
                                    FontSize="24"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border
                                Padding="14"
                                BackgroundColor="{StaticResource ShuttersTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Ouverts"
                                        FontSize="12"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Label
                                        Text="{Binding OpenShuttersCount}"
                                        FontSize="28"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="14"
                                BackgroundColor="{StaticResource ShuttersTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Fermés"
                                        FontSize="12"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Label
                                        Text="{Binding ClosedShuttersCount}"
                                        FontSize="28"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- LIGHTS -->
                <Border
                    x:Name="LightsCard"
                    Grid.Row="1"
                    Grid.Column="0"
                    Padding="18"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource LightsTint}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    Opacity="0"
                    TranslationY="20">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLightsTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Lumières"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="{Binding LightsSummary}"
                                    FontSize="13"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10"
                                BackgroundColor="{StaticResource LightsTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                                <Label
                                    Text="💡"
                                    FontSize="24"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Label
                            Text="{Binding OnLightsCount, StringFormat='{}{0} allumées'}"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="{StaticResource LightsTint}" />

                        <Label
                            Text="{Binding TotalLightsCount, StringFormat='sur {0} zones'}"
                            FontSize="13"
                            TextColor="{StaticResource TextSecondary}" />

                    </VerticalStackLayout>
                </Border>

                <!-- SECURITY -->
                <Border
                    x:Name="SecurityCard"
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="18"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource SecurityTint}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    Opacity="0"
                    TranslationY="20">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSecurityTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Sécurité"
                                    FontSize="19"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="{Binding SecuritySubtitle}"
                                    FontSize="13"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10"
                                BackgroundColor="{StaticResource SecurityTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                                <Label
                                    Text="🔒"
                                    FontSize="24"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Label
                            Text="{Binding SecurityStatus}"
                            FontSize="30"
                            FontAttributes="Bold"
                            TextColor="{StaticResource SecurityTint}" />

                    </VerticalStackLayout>
                </Border>

                <!-- ENERGY -->
                <Border
                    x:Name="EnergyCard"
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Padding="18"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource EnergyTint}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    Opacity="0"
                    TranslationY="20">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnEnergyTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Énergie"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="{Binding EnergyHeatPumpStatus}"
                                    FontSize="13"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10"
                                BackgroundColor="{StaticResource EnergyTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                                <Label
                                    Text="⚡"
                                    FontSize="24"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                            <Border
                                Padding="14"
                                BackgroundColor="{StaticResource EnergyTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Aujourd’hui"
                                        FontSize="12"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Label
                                        Text="{Binding EnergyTodayConsumption}"
                                        FontSize="26"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource EnergyTint}" />
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                Grid.Column="1"
                                Padding="14"
                                BackgroundColor="{StaticResource EnergyTintSoft}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="Maison"
                                        FontSize="12"
                                        TextColor="{StaticResource TextSecondary}" />
                                    <Label
                                        Text="{Binding EnergyIndoorTemperature}"
                                        FontSize="26"
                                        FontAttributes="Bold"
                                        TextColor="{StaticResource TextPrimary}" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ORGANIZATION -->
                <Border
                    x:Name="OrganizationCard"
                    Grid.Row="3"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Padding="18"
                    BackgroundColor="{StaticResource SurfaceCard}"
                    Stroke="{StaticResource AccentPrimary}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 26"
                    Opacity="0"
                    TranslationY="20">

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnOrganizationTapped" />
                    </Border.GestureRecognizers>

                    <VerticalStackLayout Spacing="14">

                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="Organisation"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />

                                <Label
                                    Text="{Binding OrganizationEventsSummary}"
                                    FontSize="13"
                                    TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>

                            <Border
                                Grid.Column="1"
                                Padding="10"
                                BackgroundColor="{StaticResource SurfaceCardAlt}"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">
                                <Label
                                    Text="🗓️"
                                    FontSize="24"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="8">
                            <Label
                                Text="Agenda"
                                FontSize="13"
                                TextColor="{StaticResource TextSecondary}" />

                            <CollectionView
                                ItemsSource="{Binding OrganizationUpcomingEvents}"
                                SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Padding="12"
                                            Margin="0,0,0,8"
                                            BackgroundColor="{StaticResource SurfaceCardAlt}"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 16">
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <Label
                                                    Text="{Binding StartDate, StringFormat='{0:HH:mm}'}"
                                                    FontSize="14"
                                                    FontAttributes="Bold"
                                                    TextColor="{StaticResource AccentPrimary}" />

                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label
                                                        Text="{Binding Title}"
                                                        FontSize="15"
                                                        FontAttributes="Bold"
                                                        TextColor="{StaticResource TextPrimary}" />

                                                    <Label
                                                        Text="{Binding StartDate, StringFormat='{0:dddd dd MMMM}'}"
                                                        FontSize="12"
                                                        TextColor="{StaticResource TextSecondary}" />
                                                </VerticalStackLayout>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>

                        <Border
                            Padding="14"
                            BackgroundColor="{StaticResource SurfaceCardAlt}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18">
                            <VerticalStackLayout Spacing="3">
                                <Label
                                    Text="Liste de courses"
                                    FontSize="12"
                                    TextColor="{StaticResource TextSecondary}" />

                                <Label
                                    Text="{Binding OrganizationShoppingSummary}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="{StaticResource TextPrimary}" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
